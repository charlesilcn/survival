{
  "name": "@evolution-system/core",
  "version": "1.0.0",
  "description": "A powerful multi-agent competitive evolution system based on natural selection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "multi-agent",
    "evolution",
    "genetic-algorithm",
    "optimization",
    "ai",
    "machine-learning",
    "competitive-evolution",
    "natural-selection"
  ],
  "author": "Evolution System Contributors <contributors@evolution-system.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/evolution-system/evolution-system.git"
  },
  "bugs": {
    "url": "https://github.com/evolution-system/evolution-system/issues"
  },
  "homepage": "https://github.com/evolution-system/evolution-system#readme",
  "dependencies": {
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0",
    "openai": "^4.20.0",
    "express": "^4.18.0",
    "socket.io": "^4.7.0",
    "bullmq": "^4.15.0",
    "ioredis": "^5.3.0",
    "commander": "^11.1.0"
  },
  "bin": {
    "evolution": "./dist/cli/index.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/express": "^4.17.0",
    "typescript": "^5.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "jest-junit": "^16.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}